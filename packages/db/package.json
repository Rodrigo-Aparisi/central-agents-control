    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@cac/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "uuidv7": "^1.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
