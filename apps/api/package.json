    "test:watch": "vitest"
  },
  "dependencies": {
    "@cac/claude-runner": "workspace:*",
    "@cac/db": "workspace:*",
    "@cac/shared": "workspace:*",
    "@fastify/sensible": "^6.0.2",
    "bullmq": "^5.34.5",
    "close-with-grace": "^2.1.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
