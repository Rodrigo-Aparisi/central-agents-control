{
  "name": "central-agents-control",
  "version": "0.0.0",
  "private": true,
  "description": "Dashboard web local para orquestar múltiples proyectos desarrollados con Claude Code",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @cac/db generate",
    "db:migrate": "pnpm --filter @cac/db migrate",
    "db:studio": "pnpm --filter @cac/db studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
