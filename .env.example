# Copiar a .env y rellenar. NUNCA commitear .env.
# Todas las variables se validan con Zod en apps/api/src/config.ts.

# --- Postgres ---
POSTGRES_USER=cac
POSTGRES_PASSWORD=cac
POSTGRES_DB=cac
POSTGRES_PORT=5432
POSTGRES_TEST_PORT=5433
DATABASE_URL=postgres://cac:cac@localhost:5432/cac
DATABASE_URL_TEST=postgres://cac:cac@localhost:5433/cac_test

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=8787
API_HOST=127.0.0.1
NODE_ENV=development
LOG_LEVEL=info

# --- Runner ---
# Ruta absoluta del binario `claude` (resolver en PATH si se deja vacío).
CLAUDE_BIN=claude
# Directorio raíz bajo el que deben vivir todos los proyectos registrados.
PROJECTS_ROOT=D:/Proyectos
# Timeout global por run en ms (default 30 min).
RUN_TIMEOUT_MS=1800000
# Concurrencia máxima del worker de runs.
MAX_CONCURRENT_RUNS=3

# --- Claude API (opcional; el runner sólo lo propaga si existe en el entorno) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Web (Vite) ---
VITE_API_URL=http://localhost:8787
VITE_SOCKET_URL=http://localhost:8787
